---
import { getEntry } from 'astro:content'

const resumeEntry = await getEntry('about', 'resume')
const items = resumeEntry?.data?.items ?? []
---

{items.length > 0 && (
<div class="resume-dropdown">
  <button class="resume-trigger" aria-expanded="false" aria-haspopup="true">
    Pull Resume
    <svg class="arrow-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class="resume-menu" role="menu">
    {items.map((item) => (
      <a href={item.url} target="_blank" rel="noopener noreferrer" role="menuitem">{item.label}</a>
    ))}
  </div>
</div>
)}

<script is:inline>
  (function initResumeDropdown() {
    const dropdown = document.querySelector('.resume-dropdown');
    if (!dropdown) return;
    const trigger = dropdown.querySelector('.resume-trigger');
    const menu = dropdown.querySelector('.resume-menu');

    function open() {
      trigger.setAttribute('aria-expanded', 'true');
      menu.classList.add('open');
    }

    function close() {
      trigger.setAttribute('aria-expanded', 'false');
      menu.classList.remove('open');
    }

    function toggle() {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggle();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target)) close();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  })();
</script>

<style>
  .resume-dropdown {
    position: relative;
  }

  .resume-trigger {
    all: unset;
    font-family: inherit;
    font-size: var(--font-size-m);
    letter-spacing: var(--spacing-m);
    color: var(--text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.15s ease-out;
    box-sizing: border-box;
    white-space: nowrap;
  }

  .resume-trigger:hover,
  .resume-trigger[aria-expanded='true'] {
    color: var(--text-primary);
  }

  .arrow-icon {
    transition: transform 0.2s ease-out;
    flex-shrink: 0;
  }

  .resume-trigger[aria-expanded='true'] .arrow-icon {
    transform: rotate(180deg);
  }

  .resume-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    display: flex;
    flex-direction: column;
    min-width: 9rem;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.25rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.15s ease-out,
      transform 0.15s ease-out,
      visibility 0.15s ease-out;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .resume-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .resume-menu a {
    font-family: inherit;
    font-size: var(--font-size-m);
    letter-spacing: var(--spacing-m);
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.4rem 0.85rem;
    transition: color 0.15s ease-out;
    white-space: nowrap;
  }

  .resume-menu a:hover {
    color: var(--text-primary);
  }
</style>
